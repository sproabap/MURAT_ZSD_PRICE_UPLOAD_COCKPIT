  }

define behavior for ZI_SdTableTypesMainten alias SdTableTypesMainten ##UNMAPPED_FIELD
persistent table ZSD_T_TABLETYPES
draft table ZSD_T_TABLETY_D
etag master LocalLastChangedAt
lock dependent by _SdTableTypesMainAll
