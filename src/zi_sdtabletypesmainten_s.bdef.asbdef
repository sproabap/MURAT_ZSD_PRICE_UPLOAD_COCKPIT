managed with additional save implementation in class ZBP_I_SDTABLETYPESMAINTEN_S unique;
strict;
with draft;
define behavior for ZI_SdTableTypesMainten_S alias SdTableTypesMainAll
draft table ZSD_T_TABLE_D_S
with unmanaged save
lock master total etag LastChangedAtMax
authorization master( global )

{
  field ( readonly )
   SingletonID;

  field ( features : instance )
   TransportRequestID;

  field ( notrigger )
   SingletonID,
   LastChangedAtMax;


  update;
  internal create;
  internal delete;

